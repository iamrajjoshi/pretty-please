pkgname=pls-git
pkgver=0.1.0
pkgrel=1
pkgdesc="The polite sudo"
arch=('x86_64' 'aarch64')
url="https://github.com/iamrajjoshi/pls"
license=('MIT' 'Apache')
depends=('sudo')
makedepends=('cargo' 'git')
source=("git+$url.git")
sha256sums=('SKIP')

pkgver() {
  cd "$srcdir/pls"
  printf "%s" "$(git describe --tags --always | sed 's/^v//; s/-/./g')"
}

build() {
  cd "$srcdir/pls"
  cargo build --locked --release --bin pls
}

check() {
  cd "$srcdir/pls"
  cargo test --locked
}

package() {
  cd "$srcdir/pls"
  install -Dm755 "target/release/pls" "$pkgdir/usr/bin/pls"
  install -Dm644 README.md "$pkgdir/usr/share/doc/pls/README.md"
  install -Dm644 LICENSE-MIT "$pkgdir/usr/share/licenses/pls/LICENSE-MIT"
  install -Dm644 LICENSE-APACHE "$pkgdir/usr/share/licenses/pls/LICENSE-APACHE"
}
